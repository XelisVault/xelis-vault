# ============================================================================
# .env.example — XELIS Vault v4.2 Configuration
# ============================================================================
# Copy this file to .env and edit the values for your environment.
# NEVER commit your .env file to git.

# === XELIS Network ===
XELIS_NETWORK=testnet  # testnet | mainnet | devnet
XELIS_RPC=http://127.0.0.1:8080  # daemon RPC URL

# === Provider Configuration (for price_provider.py) ===
# Your XELIS wallet address (must be registered as provider in StakedOracle)
PROVIDER_ADDRESS=xet1...

# StakedOracle contract hash (from deployment.json)
STAKED_ORACLE_CONTRACT=0x...

# VLT asset hash (from VLTToken.get_asset_hash)
VLT_ASSET_HASH=0x...

# Optional: CoinMarketCap API key (fallback price source)
# Get free key at https://pro.coinmarketcap.com/signup
CMC_API_KEY=

# Submit interval (seconds). Should be < 25s (one cycle)
SUBMIT_INTERVAL=20

# === Keeper Configuration (for aggregation_keeper.py) ===
# Feeds to keep aggregated (comma-separated feed names)
FEEDS_TO_KEEP=XEL/USD

# Poll interval (should match block time = 5s)
POLL_INTERVAL=5

# === Monitoring ===
PROMETHEUS_PORT=9091  # for price_provider.py
# Note: aggregation_keeper.py does not expose Prometheus metrics

# === Logging ===
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# === Deployment Configuration (for deploy_testnet.py) ===
DEPLOYER_SIGNER=deployer  # wallet name in xelis_wallet
TEAM_ADDRESS=xet1...
TREASURY_ADDRESS=xet1...
AIRDROP_ADDRESS=xet1...
BUG_BOUNTY_ADDRESS=xet1...

# === Price Source Configuration ===
# These are hardcoded in price_provider.py but documented here for reference
# Sources validated June 2026:
#   - MEXC:       api.mexc.com (XEL listed, ~$17k daily volume)
#   - CoinEx:     api.coinex.com/v2 (XEL listed, ~$6k daily volume)
#   - CoinGecko:  api.coingecko.com (aggregator, rate-limited 30/min)
#   - CoinMarketCap: pro-api.coinmarketcap.com (requires CMC_API_KEY)
#
# Sources NOT supporting XEL (June 2026):
#   - Binance, Gate.io, Kraken — XEL not yet listed
#   # When XEL gets listed, add fetcher functions in price_provider.py
