const KEY_A: string = "a"

entry bug() -> u64 {
    let dep: optional<u64> = get_deposit_for_asset(Hash::zero());  // FIRST — breaks next store
    let s: Storage = Storage::new();
    s.store(KEY_A, 42u64);        // DROPPED
    let a: u64 = s.load(KEY_A).unwrap_or(0);
    return a;  // returns 0 instead of 42
}

entry expected() -> u64 {
    let s: Storage = Storage::new();
    s.store(KEY_A, 0u64);         // DUMMY store first
    let dep: optional<u64> = get_deposit_for_asset(Hash::zero());  // now safe
    s.store(KEY_A, 42u64);        // persists correctly
    let a: u64 = s.load(KEY_A).unwrap_or(0);
    return a;  // returns 42
}
