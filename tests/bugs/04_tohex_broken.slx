const KEY: string = "k"

entry bug() -> u64 {
    let h: Hash = Hash::from_hex("0102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f20").expect("badhex");
    let hex: string = h.to_hex();           // returns garbage or empty
    let s: Storage = Storage::new();
    s.store(KEY + hex, 42u64);               // stores under corrupted key
    return 0;
}

entry test_address() -> u64 {
    let caller: Address = get_caller().expect("nocaller");
    let s: string = caller.to_string();      // returns garbage or empty
    let s2: Storage = Storage::new();
    s2.store(KEY + s, 42u64);                // stores under corrupted key
    return 0;
}
