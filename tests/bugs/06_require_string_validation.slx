const KEY: string = "k"

entry bug() -> u64 {
    let s: Storage = Storage::new();
    let v: u64 = s.load(KEY).unwrap_or(0);
    require(v == 1, "v is not 1");    // space in string → execution fails
    return 0;
}

entry bug2() -> u64 {
    let s: Storage = Storage::new();
    let v: u64 = s.load(KEY).expect("not found!");  // exclamation → fails
    return v;
}

entry works() -> u64 {
    let s: Storage = Storage::new();
    let v: u64 = s.load(KEY).unwrap_or(0);
    require(v == 0, "vnot1");          // alphanumeric only → works
    return 0;
}
