# ============================================================================
# .gitignore — XELIS Vault v4.2
# ============================================================================

# Environment files (contain secrets)
.env
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# OS
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# XELIS daemon data
.xelis/
*.db
*.lock

# Compiled contracts (if compiled locally)
*.compiled
contracts/**/*.compiled

# Deployment artifacts
deployment.json
deployment-*.json

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/

# Documentation build
docs/_build/
site/

# Temporary files
*.tmp
*.bak
*.cache
