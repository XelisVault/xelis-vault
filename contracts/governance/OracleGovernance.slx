        created_at: topo,
        voting_deadline: topo + voting_period,
        executed: false,
        cancelled: false,
        yes_votes: 0,
        no_votes: 0,
        feed_id: feed_id,
        feed_name: "",
        feed_asset: Hash::zero(),
        feed_decimals: 0,
        feed_min: 0,
        feed_max: 0,
        param_key: 0,
