const VERSION: string = "AssetVault v4.2"

const ISSUER_KEY: string = "i"
const TIMELOCK_KEY: string = "tl"
const PAUSED_KEY: string = "pz"
const REGISTRY_KEY: string = "reg"
const COMPLIANCE_KEY: string = "cm"

const ASSET_HASH_KEY: string = "ah"
const ASSET_NAME_KEY: string = "an"
const ASSET_TICKER_KEY: string = "at"
const ASSET_DECIMALS_KEY: string = "ad"
const ASSET_MAX_SUPPLY_KEY: string = "ams"
const TOTAL_MINTED_KEY: string = "tm"

hook constructor() -> u64 {
    let s: Storage = Storage::new()
    let caller: Address = get_caller().unwrap()
    s.store(ISSUER_KEY, caller)
    s.store(PAUSED_KEY, false)
    s.store(TOTAL_MINTED_KEY, 0u64)
    return 0
}

fn only_issuer() {
    let s: Storage = Storage::new()
    let caller: Address = get_caller().unwrap()
    let issuer: Address = s.load(ISSUER_KEY).unwrap()
    require(caller == issuer, "notissuer")
}

fn when_not_paused() {
    let paused: bool = Storage::new().load(PAUSED_KEY).unwrap_or(false)
    require(!paused, "paused")
}

entry create_asset(
    name: string,
    ticker: string,
    decimals: u8,
    max_supply: u64
) -> u64 {
    only_issuer()
    let s: Storage = Storage::new()
    let existing: optional<Hash> = s.load(ASSET_HASH_KEY)
    require(existing.is_none(), "exists")
    require(name != "" && ticker != "", "emptyname")
    require(decimals >= 0 && decimals <= 18, "baddec")
    require(max_supply > 0, "badmax")

    let asset: Asset = Asset::create(
        max_supply,
        name,
        ticker,
        decimals,
        MaxSupplyMode::None
    ).unwrap()
    let hash: Hash = asset.get_hash()
    s.store(ASSET_HASH_KEY, hash)
    s.store(ASSET_NAME_KEY, name)
    s.store(ASSET_TICKER_KEY, ticker)
    s.store(ASSET_DECIMALS_KEY, decimals)
    s.store(ASSET_MAX_SUPPLY_KEY, max_supply)
    return 0
}

entry mint(to: Address, amount: u64) -> u64 {
    only_issuer()
    when_not_paused()
    require(amount > 0, "amtgt0")

    let s: Storage = Storage::new()
    let hash: Hash = s.load(ASSET_HASH_KEY).unwrap()
    let asset: Asset = Asset::get_by_hash(hash).unwrap()

    let current_supply: u64 = asset.get_supply()
    let max_supply: u64 = s.load(ASSET_MAX_SUPPLY_KEY).unwrap()
    require(current_supply + amount <= max_supply, "supmax")

    let ok: bool = asset.mint(amount)
    require(ok, "mintfail")
    let ok2: bool = transfer(to, amount, hash)
    require(ok2, "txfail")

    let total: u64 = s.load(TOTAL_MINTED_KEY).unwrap_or(0)
    s.store(TOTAL_MINTED_KEY, total + amount)
    return 0
}

