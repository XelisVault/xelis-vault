entry transfer_asset(to: Address, amount: u64) -> u64 {
    when_not_paused()
    require(amount > 0, "amtgt0")
    let caller: Address = get_caller().unwrap()
    require(to != caller, "selfxfer")

    let s: Storage = Storage::new()
    let hash: Hash = s.load(ASSET_HASH_KEY).unwrap()
    let dep: optional<u64> = get_deposit_for_asset(hash)
    require(dep.is_some() && dep.unwrap() >= amount, "nodep")

    let compliance_opt: optional<Hash> = s.load(COMPLIANCE_KEY)
    if compliance_opt.is_some() {
        let compliance: Contract = Contract::new(compliance_opt.unwrap()).unwrap()
        let allowed: bool = compliance.call(0u16, [caller, to, hash, amount], {})
        require(allowed, "notallowed")
    }

    let ok: bool = transfer(to, amount, hash)
    require(ok, "txfail")

    if dep.unwrap() > amount {
        transfer(caller, dep.unwrap() - amount, hash)
    }
    return 0
}

entry pause(reason: string) -> u64 {
    only_issuer()
    Storage::new().store(PAUSED_KEY, true)
    return 0
}

entry unpause() -> u64 {
    only_issuer()
    Storage::new().store(PAUSED_KEY, false)
    return 0
}

pub fn get_asset_info() -> (string, string, u8, u64, u64) {
    let s: Storage = Storage::new()
    return (
        s.load(ASSET_NAME_KEY).unwrap_or(""),
        s.load(ASSET_TICKER_KEY).unwrap_or(""),
        s.load(ASSET_DECIMALS_KEY).unwrap_or(0),
        s.load(ASSET_MAX_SUPPLY_KEY).unwrap_or(0),
        s.load(TOTAL_MINTED_KEY).unwrap_or(0)
    )
}

pub fn get_asset_hash() -> Hash {
    return Storage::new().load(ASSET_HASH_KEY).unwrap()
}

pub fn get_total_supply() -> u64 {
    let s: Storage = Storage::new()
    let hash: Hash = s.load(ASSET_HASH_KEY).unwrap()
    let asset: Asset = Asset::get_by_hash(hash).unwrap()
    return asset.get_supply()
}

entry set_compliance(cm: Hash) -> u64 {
    only_issuer()
    Storage::new().store(COMPLIANCE_KEY, cm)
    return 0
}

entry set_registry(reg: Hash) -> u64 {
    only_issuer()
    Storage::new().store(REGISTRY_KEY, reg)
    return 0
}

entry set_timelock(tl: Hash) -> u64 {
    only_issuer()
    Storage::new().store(TIMELOCK_KEY, tl)
    return 0
}

