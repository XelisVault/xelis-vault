}

// List vault IDs owned by a user (off-chain pagination)
// Note: This iterates all vaults — for large vault counts, prefer an off-chain indexer.
pub fn get_vault_ids_for_user_paginated(user: Address, offset: u64, limit: u64) -> u64[] {
    let s: Storage = Storage::new()
    let total: u64 = s.load(COUNTER_KEY).unwrap_or(1)
    let total = total - 1
    let result: u64[] = []
    let i: u64 = 1  // vault IDs start at 1
    let skipped: u64 = 0
    let collected: u64 = 0
    while i <= total && collected < limit {
        let vault_opt: optional<VaultSnapshot> = s.load(VAULT_PREFIX + i.to_string(10u32))
        if vault_opt.is_some() {
            let vault: VaultSnapshot = vault_opt.expect("err")
            if vault.owner == user && !vault.liquidated {
                if skipped >= offset {
                    result.push(i)
                    collected += 1
                } else {
                    skipped += 1
                }
            }
        }
        i += 1
    }
    return result
}
