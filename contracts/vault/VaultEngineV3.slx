// ID 31: set_emergency
entry set_emergency(e: Address) -> u64 { only_emergency() Storage::new().store(EMERGENCY_KEY, e) return 0 }

// ID 32: get_version
entry get_version() -> string { return VERSION }

// ID 33: is_paused
entry is_paused() -> bool { return Storage::new().load(PAUSED_KEY).unwrap_or(false) }

// ID 34: request_emergency_withdraw
entry request_emergency_withdraw() -> u64 {
    let s: Storage = Storage::new()
    let caller: Address = get_caller().expect("err")
    let e: Address = s.load(EMERGENCY_KEY).expect("err")
    require(caller == e, "notemg")
    s.store(EMERGENCY_REQUEST_TOPO_KEY, get_current_topoheight())
    return 0
}

// ID 35: execute_emergency_withdraw
entry execute_emergency_withdraw(asset: Hash) -> u64 {
    let s: Storage = Storage::new()
    let caller: Address = get_caller().expect("err")
    let e: Address = s.load(EMERGENCY_KEY).expect("err")
    require(caller == e, "notemg")
    let req_topo: u64 = s.load(EMERGENCY_REQUEST_TOPO_KEY).unwrap_or(0)
    require(req_topo > 0, "norequest")
    let now_topo: u64 = get_current_topoheight()
    require(now_topo >= req_topo + EMERGENCY_DELAY_BLOCKS, "toosoon")
    s.delete(EMERGENCY_REQUEST_TOPO_KEY)
    let bal: u64 = get_balance_for_asset(asset).unwrap_or(0)
    if bal > 0 { transfer(caller, bal, asset) }
    return 0
}

// ============================================================================
// pub fn (read-only) — for off-chain frontend reads via `invoke` (no gas)
// These do NOT count toward entry ID numbering.
// ============================================================================

pub fn set_timelock_tl(tl: Hash) -> u64 { only_admin() Storage::new().store(TIMELOCK_KEY, tl) return 0 }

pub fn get_treasury() -> Address { return Storage::new().load(TREASURY_KEY).unwrap_or(get_caller().expect("err")) }

pub fn total_vaults() -> u64 {
    let c: optional<u64> = Storage::new().load(COUNTER_KEY)
    return c.unwrap_or(1) - 1
}

pub fn redemption_queue_size() -> u64 {
    return queue_size()
}

pub fn get_vault(vault_id: u64) -> (Address, Hash, u64, u64, u64, bool, u64) {
    let s: Storage = Storage::new()
    let vault: VaultSnapshot = s.load(VAULT_PREFIX + vault_id.to_string(10u32)).expect("err")
    return (
        vault.owner, vault.collateral_asset, vault.collateral_amount,
        vault.borrow_amount, vault.last_update_topo,
        vault.liquidated, vault.id
    )
}

pub fn get_health_factor(vault_id: u64) -> u64 {
    let rs: Storage = Storage::new()
    let vault_opt: optional<VaultSnapshot> = rs.load(VAULT_PREFIX + vault_id.to_string(10u32))
    if vault_opt.is_none() { return 0 }
    let vault: VaultSnapshot = vault_opt.expect("err")
    if vault.liquidated { return 0 }
    let accrued_bp: u64 = get_accrued_borrow(vault)
    return calc_health_factor_bps(vault.collateral_amount, accrued_bp)
}

pub fn get_vault_health(vault_id: u64) -> u64 {
    return get_health_factor(vault_id)
}

pub fn get_accrued_borrow_view(vault_id: u64) -> u64 {
    let s: Storage = Storage::new()
    let vault: VaultSnapshot = s.load(VAULT_PREFIX + vault_id.to_string(10u32)).expect("err")
    return get_accrued_borrow(vault)
}

pub fn get_config_public() -> (u64, u64, u64, u64, u64, u64, u64) {
    let s: Storage = Storage::new()
    return (
        s.load(MIN_CR_KEY).unwrap_or(DEFAULT_MIN_CR),
        s.load(LIQ_PENALTY_KEY).unwrap_or(DEFAULT_LIQ_PENALTY),
        s.load(PROTOCOL_FEE_KEY).unwrap_or(DEFAULT_PROTOCOL_FEE),
        s.load(INSURANCE_FEE_KEY).unwrap_or(DEFAULT_INSURANCE_FEE),
        s.load(REDEMPTION_FEE_KEY).unwrap_or(DEFAULT_REDEMPTION_FEE),
        s.load(GRACE_PERIOD_KEY).unwrap_or(DEFAULT_GRACE_PERIOD),
        s.load(STABILITY_FEE_BPS_KEY).unwrap_or(DEFAULT_STABILITY_FEE_BPS)
    )
}

pub fn get_stability_fee_index() -> u64 {
    return Storage::new().load(STABILITY_FEE_INDEX_KEY).unwrap_or(STABILITY_FEE_SCALE)
}

pub fn get_stability_fee_bps() -> u64 {
