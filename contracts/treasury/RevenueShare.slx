const ADMIN_KEY: string = "a"
const SHARE_PREFIX: string = "rs"
const COUNTER_KEY: string = "n"

struct RevenueShare {
    name_string: string,
    total_shares: u64,
    distributed: u64,
    active: bool
}

hook constructor() -> u64 {
    let s: Storage = Storage::new();
    s.store(ADMIN_KEY, get_caller().expect("nocaller"));
    s.store(COUNTER_KEY, 0u64);
    return 0;
}

fn only_admin() {
    let s: Storage = Storage::new();
    let caller: Address = get_caller().expect("nocaller");
    let admin: Address = s.load(ADMIN_KEY).expect("anset");
    require(caller == admin, "notauth");
}

fn get_share_key(id: u64) -> string {
    return SHARE_PREFIX + id.to_string(10u32);
}

entry create_share(name: string, total_shares: u64) -> u64 {
    only_admin();
    require(total_shares > 0, "sharesgt0");
    let rs: Storage = Storage::new();
    let id: u64 = rs.load(COUNTER_KEY).expect("idns");
    let share: RevenueShare = RevenueShare {
        name_string: name,
        total_shares: total_shares,
        distributed: 0,
        active: true
    };
    let ws: Storage = Storage::new();
    ws.store(get_share_key(id), share);
    ws.store(COUNTER_KEY, id + 1);
    return id;
}

entry deposit_revenue(share_id: u64) -> u64 {
    let rs: Storage = Storage::new();
    let share: RevenueShare = rs.load(get_share_key(share_id)).expect("snf");
    require(share.active, "inactive");
    let dep: optional<u64> = get_deposit_for_asset(Hash::zero());
    require(dep.is_some() && dep.unwrap() > 0, "nodep");
    let amount: u64 = dep.unwrap();
    share.distributed += amount;
    let ws: Storage = Storage::new();
    ws.store(get_share_key(share_id), share);
    return 0;
}

entry claim_dividends(share_id: u64, claimant_shares: u64) -> u64 {
    let caller: Address = get_caller().expect("nocaller");
    let rs: Storage = Storage::new();
    let share: RevenueShare = rs.load(get_share_key(share_id)).expect("snf");
    require(share.active, "inactive");
    require(claimant_shares <= share.total_shares, "exceed");
    let amount: u64 = share.distributed * claimant_shares / share.total_shares;
    require(amount > 0, "amtgt0");
    share.distributed -= amount;
    let ok: bool = transfer(caller, amount, Hash::zero());
    require(ok, "txfail");
    let ws: Storage = Storage::new();
    ws.store(get_share_key(share_id), share);
    return amount;
}

entry get_share(share_id: u64) -> optional<RevenueShare> {
    let rs: Storage = Storage::new();
    return rs.load(get_share_key(share_id));
}

entry transfer_admin(new_admin: Address) -> u64 {
    only_admin();
    let ws: Storage = Storage::new();
    ws.store(ADMIN_KEY, new_admin);
    return 0;
}
