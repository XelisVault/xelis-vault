    "url": "https://api.simple-price.com/xel",
    "json_path": "price",
    "timeout": 10
  },
  {
    "_comment": "EXAMPLE 3 — Command source (external script)",
    "name": "my_script",
    "type": "command",
    "command": "/usr/local/bin/fetch_xel_price.sh",
