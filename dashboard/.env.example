# XELIS Vault Environment Variables
# Copy this file to .env.local and fill in your values

# Supabase (for future integration)
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxxx

# XELIS Network
VITE_XELIS_DAEMON_URL=http://127.0.0.1:18081
VITE_XELIS_WALLET_URL=http://127.0.0.1:18082

# Contract Addresses (when deployed)
VITE_VAULT_CONTRACT_ADDRESS=
VITE_XUSD_CONTRACT_ADDRESS=
VITE_ORACLE_CONTRACT_ADDRESS=
VITE_VLT_CONTRACT_ADDRESS=

# Analytics (optional)
VITE_GA_ID=
VITE_POSTHOG_KEY=

# API Endpoints
VITE_API_URL=http://localhost:3001
VITE_API_TIMEOUT=30000

# Features
VITE_ENABLE_TESTNET=true
VITE_ENABLE_ANALYTICS=false
